class Solution {
    public ListNode reverseKGroup(ListNode head, int k) {
        // Step 1: Check if there are k nodes to reverse
        ListNode curr = head;
        int count = 0;
        while (count < k) {
            if (curr == null) return head; // Fewer than k nodes, return as is
            curr = curr.next;
            count++;
        }

        // Step 2: Reverse k nodes
        ListNode prev = null;
        ListNode next = null;
        ListNode temp = head;
        for (int i = 0; i < k; i++) {
            next = temp.next;
            temp.next = prev;
            prev = temp;
            temp = next;
        }

        // Step 3: Recursive call for the next group
        // head is now the tail of the reversed segment
        if (next != null) {
            head.next = reverseKGroup(next, k);
        }

        // prev is the new head of this reversed segment
        return prev;
    }
}
